{
  "name": "harness",
  "description": "Lean modular harness — feedforward + feedback sensors for Claude Code.",
  "author": {
    "name": "Leon Dixon"
  },
  "homepage": "https://github.com/leondixon/harness",
  "repository": "https://github.com/leondixon/harness",
  "license": "MIT",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/harness/01-context.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/harness/02-checks.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/harness/03-verify.sh"
          }
        ]
      }
    ]
  }
}
